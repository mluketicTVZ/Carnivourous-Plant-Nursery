{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"$(git rev-parse --show-toplevel)/.codex/hooks/log-user-prompt.ps1\"",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& { & (Join-Path (git rev-parse --show-toplevel) '.codex/hooks/log-user-prompt.ps1') }\"",
            "timeout": 10,
            "statusMessage": "Logging user prompt"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"$(git rev-parse --show-toplevel)/.codex/hooks/log-user-prompt.ps1\"",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& { & (Join-Path (git rev-parse --show-toplevel) '.codex/hooks/log-user-prompt.ps1') }\"",
            "timeout": 10,
            "statusMessage": "Logging tool use"
          }
        ]
      }
    ]
  }
}
