@model IEnumerable<Carnivorous_Plant_Nursery.Models.InventoryItem>

@{
    ViewData["Title"] = "Nursery Check Stock";
}

<div class="nursery-breadcrumb">
    <a asp-controller="Home" asp-action="Index">Home</a> <span class="separator">&raquo;</span>
    <span>Inventory Stock</span>
</div>

<partial name="_BackButton" />

<div style="margin-bottom: 2rem;">
    <h1 style="color: #104e8b; border-bottom: 3px solid #4682b4; padding-bottom: 10px; display: inline-block;">Current Stock</h1>
    <p style="color: var(--text-muted); font-size: 1.1rem; margin-top: 10px;">
        Monitor our nursery availability, from young seedlings to mature specimens.
    </p>
</div>

<form method="get" asp-action="Index" class="inventory-filter-form">
    <div class="filter-group">
        <label for="searchTerm">Search Inventory SKU / Name</label>
        <input type="text" id="searchTerm" name="searchTerm" value="@ViewBag.SearchTerm" placeholder="Enter SKU or name..." />
    </div>

    <div class="filter-group filter-group-checkbox">
        <label>
            <input type="checkbox" name="webshopOnly" value="true" @(ViewBag.WebshopOnly == true ? "checked" : "") />
            Available in Webshop Only
        </label>
    </div>

    <div style="display: flex; gap: 10px; margin-left: auto;">
        <button type="submit" class="btn-filter-inventory">Scan Inventory</button>
        <a asp-action="Index" class="btn-clear" style="text-align: center;">Clear</a>
    </div>
</form>

<div class="entity-catalog">
    @foreach (var item in Model)
    {
        <!-- Evaluate status class based on quantity -->
        var statusClass = item.IsAvailableInWebshop ? "status-instock" : "status-out";
        var statusText = item.IsAvailableInWebshop ? "Available" : "Not listed";

        <div class="inventory-card">
            <div class="inventory-card-header">
                <h2 class="inventory-card-title">@(item.Taxonomy?.CommonName ?? item.ListingTitle)</h2>
                <div class="inventory-card-subtitle">SKU: @item.SKU</div>
            </div>
            <div class="inventory-card-body">
                <p><span class="card-label">Item ID:</span> #@item.Id</p>
                <p><span class="card-label">Price:</span> $@item.Price?.ToString("0.00")</p>
                <p><span class="card-label">Location:</span> @item.LocationInNursery</p>
                
                @if (item is Carnivorous_Plant_Nursery.Models.SeedBatch sb)
                {
                    <div style="margin-top: 0.5rem; padding: 0.5rem; background-color: rgba(70, 130, 180, 0.1); border-radius: 4px; border-left: 3px solid #4682b4;">
                        <p style="margin: 0; font-size: 0.9rem; color: #104e8b;"><strong>Type:</strong> Seed Batch</p>
                        <p style="margin: 0; font-size: 0.9rem;"><span class="card-label">Count:</span> @(sb.SeedCount?.ToString() ?? "Unknown") seeds</p>
                    </div>
                }

                <div style="margin-top: 1rem; border-top: 1px dashed #4682b4; padding-top: 1rem;">
                    <span class="status-badge @statusClass">@statusText</span>
                </div>
            </div>
            <div class="inventory-card-footer">
                <a asp-action="Details" asp-route-id="@item.Id" class="btn-inventory">View Status &raquo;</a>
            </div>
        </div>
    }
</div>
