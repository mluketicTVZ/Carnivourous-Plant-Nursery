@model Carnivorous_Plant_Nursery.Models.Plant

@{
    ViewData["Title"] = Model.Taxonomy?.CommonName + " - Details";
}

<div class="nursery-breadcrumb">
    <a asp-controller="Home" asp-action="Index">Home</a> <span class="separator">&raquo;</span>
    <a asp-action="Index">Plants</a> <span class="separator">&raquo;</span>
    <span>@Model.Taxonomy?.CommonName</span>
</div>

<partial name="_BackButton" />

@if (TempData["DeleteError"] != null)
{
    <div class="toast-notification" data-autodismiss="true">
        <div class="toast-icon">⚠️</div>
        <div class="toast-content">
            <h4 class="toast-title">Cannot delete</h4>
            <p class="toast-message">@TempData["DeleteError"]</p>
        </div>
        <button type="button" class="toast-close" onclick="closeToast(this.closest('.toast-notification'))">&times;</button>
    </div>
}

<div class="entity-details-wrapper">
    <div class="details-header">
        <div class="details-title-row">
            <div>
                <h1>@Model.Taxonomy?.CommonName</h1>
                <div class="scientific-name">@Model.Taxonomy?.FullName</div>
                @if (!string.IsNullOrEmpty(Model.ListingTitle))
                {
                    <div style="font-style: italic; color: var(--dark-green); margin-top: 0.5rem; font-size: 1.1rem;">@Model.ListingTitle</div>
                }
            </div>
            <partial name="_AttachmentGallery"
                     model="Model.Attachments"
                     view-data='@(new ViewDataDictionary(ViewData) {
                         { "GallerySize", "hero" },
                         { "GalleryLabel", $"Photos for {Model.Taxonomy?.CommonName ?? Model.ListingTitle ?? "plant"}" }
                     })' />
        </div>
    </div>
    
    <div class="details-content">
        <div class="details-section">
            <h3>Botanical Classification</h3>
            <div class="data-row">
                <span class="card-label">SKU</span>
                <span>@(string.IsNullOrEmpty(Model.SKU) ? "N/A" : Model.SKU)</span>
            </div>
            <div class="data-row">
                <span class="card-label">Genus</span>
                <span>@Model.Taxonomy?.Genus</span>
            </div>
            <div class="data-row">
                <span class="card-label">Species</span>
                <span>@Model.Taxonomy?.Species</span>
            </div>
            <div class="data-row">
                <span class="card-label">Cultivar</span>
                <span>@(string.IsNullOrEmpty(Model.Taxonomy?.Cultivar) ? "Natural Species (None)" : Model.Taxonomy?.Cultivar)</span>
            </div>
            <div class="data-row">
                <span class="card-label">Growth Stage</span>
                <span>@Model.CurrentStage</span>
            </div>
            <div class="data-row">
                <span class="card-label">Health</span>
                <span>@Model.HealthStatus</span>
            </div>
        </div>

        <div class="details-section">
            <h3>Care & Habitat Profile</h3>
            <div class="data-row">
                <span class="card-label">Light</span>
                <span>@Model.Taxonomy?.CareProfile?.RequiredLight</span>
            </div>
            <div class="data-row">
                <span class="card-label">Humidity</span>
                <span>@Model.Taxonomy?.CareProfile?.RequiredHumidity</span>
            </div>
            <div class="data-row">
                <span class="card-label">Soil/Media</span>
                <span>@Model.Taxonomy?.CareProfile?.SoilMix</span>
            </div>
            @if (TempData["DeleteError"] != null)
            {
                <div style="background-color: #fdecea; border: 1px solid #f44336; border-left: 4px solid #c0392b; border-radius: 6px; padding: 1rem 1.2rem; margin-bottom: 1rem;">
                    <strong style="color: #c0392b;">Cannot delete:</strong>
                    <span style="color: #333;">@TempData["DeleteError"]</span>
                </div>
            }
            <div class="action-panel" style="margin-top: 2rem;">
                <a asp-action="Index" class="btn-leaf" style="background-color: var(--text-muted);">
                    &laquo; Back to List
                </a>
                <a asp-controller="Inventory" asp-action="Index" class="btn-leaf">
                    Check Availability
                </a>
                @if (User.IsInRole(AuthorizationRole.Admin) || User.IsInRole(AuthorizationRole.Manager))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-leaf">&#9998; Edit</a>
                }
                @if (User.IsInRole(AuthorizationRole.Admin))
                {
                    <form id="delete-form-plant" asp-action="Delete" asp-route-id="@Model.Id" method="post" style="display: inline;">
                        @Html.AntiForgeryToken()
                        <button type="button" class="btn-leaf" style="background-color: #c0392b; border-color: #c0392b;" onclick="openDeleteModal('delete-form-plant', 'this plant')">&#128465; Delete</button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>
