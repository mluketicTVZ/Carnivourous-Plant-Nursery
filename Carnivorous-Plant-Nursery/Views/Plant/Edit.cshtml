@using Carnivorous_Plant_Nursery.Models
@model Carnivorous_Plant_Nursery.Models.Plant

@{
    ViewData["Title"] = "Edit Plant";
    var plantId = Model?.Id ?? 0;
    var plantTitle = Model?.ListingTitle ?? Model?.Taxonomy?.CommonName ?? "Plant #" + plantId;
}

<div class="nursery-breadcrumb">
    <a asp-controller="Home" asp-action="Index">Home</a> <span class="separator">&rsaquo;</span>
    <a asp-action="Index">Plants</a> <span class="separator">&rsaquo;</span>
    <span>Edit</span>
</div>

<partial name="_BackButton" />

<partial name="_ValidationToast" />

<div class="entity-form-wrapper">
    <h1 class="form-title">Edit Plant: @plantTitle</h1>
    <form asp-action="Edit" asp-route-id="@plantId" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <fieldset class="details-section">
            <legend>Listing Info</legend>
            <div class="filter-group">
                <label asp-for="SKU" class="card-label"></label>
                <input asp-for="SKU" />
                <span asp-validation-for="SKU" class="val-error"></span>
            </div>
            <div class="filter-group">
                <label asp-for="ListingTitle" class="card-label"></label>
                <input asp-for="ListingTitle" />
                <span asp-validation-for="ListingTitle" class="val-error"></span>
            </div>
            <div class="filter-group">
                <label asp-for="Price" class="card-label"></label>
                <input type="number" asp-for="Price" step="0.01" min="0" />
                <span asp-validation-for="Price" class="val-error"></span>
            </div>
            <div class="filter-group filter-group-checkbox">
                <label>
                    <input type="checkbox" asp-for="IsAvailableInWebshop" />
                    @Html.DisplayNameFor(m => m.IsAvailableInWebshop)
                </label>
                <span asp-validation-for="IsAvailableInWebshop" class="val-error"></span>
            </div>
            <div class="filter-group">
                <label asp-for="Description" class="card-label"></label>
                <textarea asp-for="Description" rows="3"></textarea>
                <span asp-validation-for="Description" class="val-error"></span>
            </div>
        </fieldset>

        <fieldset class="details-section">
            <legend>Acquisition & Location</legend>
            <div class="filter-group">
                <label asp-for="TaxonomyId" class="card-label"></label>
                <partial name="_PlantAutocomplete"
                    model="@(Model?.Taxonomy?.FullName ?? "")"
                    view-data='@(new ViewDataDictionary(ViewData) {
                        { "Endpoint", "/taxonomy/id-suggestions" },
                        { "Placeholder", "Search by common name, genus or species..." },
                        { "FieldName", "TaxonomyId" },
                        { "InitialValue", Model?.TaxonomyId?.ToString() ?? "" },
                        { "Mode", "select" }
                    })' />
                <span asp-validation-for="TaxonomyId" class="val-error"></span>
            </div>
            <div class="filter-group" style="opacity:0.45; pointer-events:none;">
                <label asp-for="LineageId" class="card-label"></label>
                <div style="font-size: 0.8rem; color: var(--text-muted);">(lineage tracking — coming soon)</div>
                <input type="number" asp-for="LineageId" min="1" disabled />
            </div>
            <div class="filter-group">
                <label asp-for="DateAcquired" class="card-label"></label>
                <partial name="_DatePicker"
                    view-data='@(new ViewDataDictionary(ViewData) {
                        { "FieldName", "DateAcquired" },
                        { "CurrentValue", Model?.DateAcquired?.ToString("yyyy-MM-dd") ?? "" }
                    })' />
                <span asp-validation-for="DateAcquired" class="val-error"></span>
            </div>
            <div class="filter-group">
                <label asp-for="LocationInNursery" class="card-label"></label>
                <input asp-for="LocationInNursery" />
                <span asp-validation-for="LocationInNursery" class="val-error"></span>
            </div>
            <div class="filter-group">
                <label asp-for="InternalNotes" class="card-label"></label>
                <textarea asp-for="InternalNotes" rows="2"></textarea>
                <span asp-validation-for="InternalNotes" class="val-error"></span>
            </div>
        </fieldset>

        <fieldset class="details-section">
            <legend>Botanical Info</legend>
            <div class="filter-group">
                <label asp-for="CurrentStage" class="card-label"></label>
                <partial name="_HybridDropdown"
                    model="@(Enum.GetValues(typeof(Carnivorous_Plant_Nursery.Models.PlantStage)).Cast<Carnivorous_Plant_Nursery.Models.PlantStage>().Select(e => new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem { Text = e.ToString(), Value = e.ToString() }))"
                    view-data='@(new ViewDataDictionary(ViewData) {
                        { "FieldName", "CurrentStage" },
                        { "CurrentValue", Model?.CurrentStage?.ToString() },
                        { "Placeholder", "-- Select Stage --" }
                    })' />
                <span asp-validation-for="CurrentStage" class="val-error"></span>
            </div>
            <div class="filter-group">
                <label asp-for="EstimatedAgeAtAcquiryYears" class="card-label"></label>
                <input type="number" asp-for="EstimatedAgeAtAcquiryYears" min="0" />
                <span asp-validation-for="EstimatedAgeAtAcquiryYears" class="val-error"></span>
            </div>
            <div class="filter-group">
                <label asp-for="PotDiameterCm" class="card-label"></label>
                <input type="number" asp-for="PotDiameterCm" step="0.01" min="0" />
                <span asp-validation-for="PotDiameterCm" class="val-error"></span>
            </div>
            <div class="filter-group">
                <label asp-for="PotHeightCm" class="card-label"></label>
                <input type="number" asp-for="PotHeightCm" step="0.01" min="0" />
                <span asp-validation-for="PotHeightCm" class="val-error"></span>
            </div>
            <div class="filter-group">
                <label asp-for="LastRepottingDate" class="card-label"></label>
                <partial name="_DatePicker"
                    view-data='@(new ViewDataDictionary(ViewData) {
                        { "FieldName", "LastRepottingDate" },
                        { "CurrentValue", Model?.LastRepottingDate?.ToString("yyyy-MM-dd") ?? "" }
                    })' />
                <span asp-validation-for="LastRepottingDate" class="val-error"></span>
            </div>
            <div class="filter-group">
                <label asp-for="LastDormancyDateStart" class="card-label"></label>
                <partial name="_DatePicker"
                    view-data='@(new ViewDataDictionary(ViewData) {
                        { "FieldName", "LastDormancyDateStart" },
                        { "CurrentValue", Model?.LastDormancyDateStart?.ToString("yyyy-MM-dd") ?? "" }
                    })' />
                <span asp-validation-for="LastDormancyDateStart" class="val-error"></span>
            </div>
            <div class="filter-group">
                <label asp-for="LastDormancyDateEnd" class="card-label"></label>
                <partial name="_DatePicker"
                    view-data='@(new ViewDataDictionary(ViewData) {
                        { "FieldName", "LastDormancyDateEnd" },
                        { "CurrentValue", Model?.LastDormancyDateEnd?.ToString("yyyy-MM-dd") ?? "" }
                    })' />
                <span asp-validation-for="LastDormancyDateEnd" class="val-error"></span>
            </div>
        </fieldset>

        <fieldset class="details-section">
            <legend>Propagation Source</legend>
            <div class="filter-group">
                <label class="card-label">Source Seed Batch</label>
                <div style="font-size: 0.8rem; color: var(--text-muted);">(Optionally link this plant to the seed batch it was grown from)</div>
                <partial name="_PlantAutocomplete"
                    model="@(Model?.SourceSeedBatch?.ListingTitle ?? "")"
                    view-data='@(new ViewDataDictionary(ViewData) {
                        { "Endpoint", "/seeds/batch-suggestions" },
                        { "Placeholder", "Search seed batches by title or SKU..." },
                        { "FieldName", "SourceSeedBatchId" },
                        { "InitialValue", Model?.SourceSeedBatchId?.ToString() ?? "" },
                        { "Mode", "select" }
                    })' />
                <span asp-validation-for="SourceSeedBatchId" class="val-error"></span>
            </div>
        </fieldset>

        <fieldset class="details-section">
            <legend>Health</legend>
            <div class="filter-group">
                <label asp-for="HealthStatus" class="card-label"></label>
                <partial name="_HybridDropdown"
                    model="@(Enum.GetValues(typeof(Carnivorous_Plant_Nursery.Models.HealthState)).Cast<Carnivorous_Plant_Nursery.Models.HealthState>().Select(e => new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem { Text = e.ToString(), Value = e.ToString() }))"
                    view-data='@(new ViewDataDictionary(ViewData) {
                        { "FieldName", "HealthStatus" },
                        { "CurrentValue", Model?.HealthStatus?.ToString() },
                        { "Placeholder", "-- Select Status --" }
                    })' />
                <span asp-validation-for="HealthStatus" class="val-error"></span>
            </div>
            <div class="filter-group">
                <label asp-for="HealthDescription" class="card-label"></label>
                <textarea asp-for="HealthDescription" rows="3"></textarea>
                <span asp-validation-for="HealthDescription" class="val-error"></span>
            </div>
        </fieldset>

        <fieldset class="details-section plant-attachment-section">
            <legend>Plant Photos</legend>
            <div class="plant-dropzone"
                 id="plant-dropzone"
                 role="button"
                 tabindex="0"
                 data-upload-url="@Url.Action("UploadAttachment", "Plant", new { id = plantId })">
                <input type="file" id="plant-attachment-input" accept="image/*" multiple hidden />
                <div class="dropzone-icon">+</div>
                <div>
                    <strong>Drop plant images here</strong>
                    <span>or click to browse. JPG, PNG, WEBP, and GIF files up to 5 MB are accepted.</span>
                </div>
            </div>
            <div class="plant-attachment-status val-error" id="plant-attachment-status" hidden></div>
            <div class="plant-attachment-list"
                 id="plant-attachment-list"
                 data-list-url="@Url.Action("Attachments", "Plant", new { id = plantId })">
            </div>
            <div id="plant-attachment-form-state"></div>
        </fieldset>

        <div style="display: flex; gap: 10px; margin-top: 20px;">
            <button type="submit" class="btn-leaf">Save Changes</button>
            <a asp-action="Details" asp-route-id="@plantId" class="btn-clear">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const dropzone = document.getElementById('plant-dropzone');
            const input = document.getElementById('plant-attachment-input');
            const status = document.getElementById('plant-attachment-status');
            const list = document.getElementById('plant-attachment-list');
            const formState = document.getElementById('plant-attachment-form-state');
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

            if (!dropzone || !input || !list || !formState || !token) {
                return;
            }

            const showStatus = (message, isError = true) => {
                if (!status) {
                    return;
                }

                status.hidden = !message;
                status.textContent = message;
                status.classList.toggle('attachment-status-ok', !isError);
            };

            const refreshList = async () => {
                const response = await fetch(list.dataset.listUrl, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                if (response.ok) {
                    list.innerHTML = await response.text();
                }
            };

            const createHidden = (name, value) => {
                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = name;
                hidden.value = value;
                formState.appendChild(hidden);
                return hidden;
            };

            const removeEmptyState = () => {
                list.querySelector('.attachment-empty-state')?.remove();
            };

            const ensureGrid = () => {
                removeEmptyState();
                let grid = list.querySelector('.plant-attachment-grid');
                if (!grid) {
                    grid = document.createElement('div');
                    grid.className = 'plant-attachment-grid';
                    list.appendChild(grid);
                }

                return grid;
            };

            const appendPendingAttachment = attachment => {
                const grid = ensureGrid();
                const card = document.createElement('article');
                card.className = 'plant-attachment-card plant-attachment-pending';

                const link = document.createElement('a');
                link.href = attachment.filePath;
                link.target = '_blank';
                link.rel = 'noopener';
                link.className = 'plant-attachment-link';

                const image = document.createElement('img');
                image.src = attachment.filePath;
                image.alt = attachment.fileName;
                image.loading = 'lazy';
                link.appendChild(image);

                const meta = document.createElement('div');
                meta.className = 'plant-attachment-meta';

                const title = document.createElement('span');
                title.title = attachment.fileName;
                title.textContent = attachment.fileName;

                const removeButton = document.createElement('button');
                removeButton.type = 'button';
                removeButton.className = 'btn-clear attachment-delete-button';
                removeButton.textContent = 'Remove';
                removeButton.addEventListener('click', () => {
                    card.remove();
                    hiddenFields.forEach(hidden => hidden.remove());
                });

                meta.append(title, removeButton);
                card.append(link, meta);
                grid.prepend(card);

                const hiddenFields = [
                    createHidden('PendingAttachmentStoredFileNames', attachment.storedFileName),
                    createHidden('PendingAttachmentFileNames', attachment.fileName),
                    createHidden('PendingAttachmentContentTypes', attachment.contentType),
                    createHidden('PendingAttachmentFileSizes', attachment.fileSize)
                ];
            };

            const uploadFiles = async files => {
                const selectedFiles = Array.from(files);
                if (selectedFiles.length === 0) {
                    return;
                }

                dropzone.classList.add('is-uploading');
                showStatus('');

                for (const file of selectedFiles) {
                    const formData = new FormData();
                    formData.append('file', file);

                    const response = await fetch(dropzone.dataset.uploadUrl, {
                        method: 'POST',
                        headers: { 'RequestVerificationToken': token },
                        body: formData
                    });

                    if (!response.ok) {
                        const payload = await response.json().catch(() => null);
                        showStatus(payload?.error ?? `Could not upload ${file.name}.`);
                        break;
                    }

                    const payload = await response.json();
                    appendPendingAttachment(payload);
                }

                input.value = '';
                dropzone.classList.remove('is-uploading');
            };

            dropzone.addEventListener('click', () => input.click());
            dropzone.addEventListener('keydown', event => {
                if (event.key === 'Enter' || event.key === ' ') {
                    event.preventDefault();
                    input.click();
                }
            });
            dropzone.addEventListener('dragover', event => {
                event.preventDefault();
                dropzone.classList.add('is-dragging');
            });
            dropzone.addEventListener('dragleave', () => {
                dropzone.classList.remove('is-dragging');
            });
            dropzone.addEventListener('drop', event => {
                event.preventDefault();
                dropzone.classList.remove('is-dragging');
                uploadFiles(event.dataTransfer.files);
            });
            input.addEventListener('change', event => uploadFiles(event.target.files));
            list.addEventListener('click', event => {
                const deleteButton = event.target.closest('[data-attachment-delete="true"]');
                if (!deleteButton) {
                    return;
                }

                const attachmentId = deleteButton.dataset.existingAttachmentId;
                if (attachmentId) {
                    createHidden('RemovedAttachmentIds', attachmentId);
                }

                deleteButton.closest('.plant-attachment-card')?.remove();
                showStatus('');
            });

            refreshList();
        })();
    </script>
}
