@{
    ViewData["Title"] = "Admin Login";
}

<div class="nursery-breadcrumb">
    <a asp-controller="Home" asp-action="Index">Home</a> <span class="separator">&rsaquo;</span>
    <span>Admin</span>
</div>

<partial name="_BackButton" />

<div class="entity-form-wrapper" style="max-width: 480px;">
    <h1 class="form-title">Account Login</h1>
    <form asp-controller="Account" asp-action="Login" method="get">
        @Html.AntiForgeryToken()

        <fieldset class="details-section">
            <legend>Nursery Account</legend>
            <p style="color: var(--text-muted);">Inventory management now uses account roles.</p>

            <div style="margin-top: 1.5rem;">
                <button type="submit" class="btn-leaf">Continue to Login</button>
            </div>
        </fieldset>
    </form>
</div>

<p style="color: var(--text-muted); font-size: 0.9rem; margin-top: 1rem; max-width: 480px;">An Admin or Manager role is required to create or edit records. Delete actions require Admin.</p>
