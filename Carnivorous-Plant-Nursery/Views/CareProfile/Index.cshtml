@model IEnumerable<Carnivorous_Plant_Nursery.Models.CareProfile>

@{
    ViewData["Title"] = "Care Requirements";
}

<div class="nursery-breadcrumb">
    <a asp-controller="Home" asp-action="Index">Home</a> <span class="separator">&raquo;</span>
    <span>Care Profiles</span>
</div>

<partial name="_BackButton" />

@if (User.IsInRole(AuthorizationRole.Admin) || User.IsInRole(AuthorizationRole.Manager))
{
    <div style="margin-bottom: 1rem;">
        <a asp-action="Create" class="btn-leaf">+ Add New Care Profile</a>
    </div>
}

<div style="margin-bottom: 2rem;">
    <h1 style="color: var(--dark-green); border-bottom: 3px solid var(--accent-color); padding-bottom: 10px; display: inline-block;">Carnivorous Plant Care Profiles</h1>
    <p style="color: var(--text-muted); font-size: 1.1rem; margin-top: 10px;">
        Learn the specific requirements to keep your botanical wonders thriving.
    </p>
</div>

<form method="get" asp-controller="CareProfile" asp-action="Index" class="botanical-filter-form" style="display: flex; gap: 15px; margin-bottom: 20px; align-items: flex-end; flex-wrap: wrap;">
    <div class="filter-group" style="flex: 1; min-width: 250px;">
        <label>Filter by Name</label>
        <partial name="_HybridDropdown"
            model="@(ViewBag.AllCareProfiles as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)"
            view-data='@(new ViewDataDictionary(ViewData) {
                { "FieldName", "searchTerm" },
                { "CurrentValue", ViewBag.SearchTerm as string },
                { "Placeholder", "-- All Care Profiles --" }
            })' />
    </div>
    <div class="filter-group" style="flex: 1; min-width: 250px;">
        <label for="requiredLight">Required Light Levels</label>
        <partial name="_HybridDropdown"
            model="@(Enum.GetValues(typeof(Carnivorous_Plant_Nursery.Models.LightLevel)).Cast<Carnivorous_Plant_Nursery.Models.LightLevel>().Select(e => new Microsoft.AspNetCore.Mvc.Rendering.SelectListItem { Text = e.ToString(), Value = e.ToString() }))"
            view-data='@(new ViewDataDictionary(ViewData) {
                { "FieldName", "requiredLight" },
                { "CurrentValue", ViewBag.RequiredLight as string },
                { "Placeholder", "-- All Light Levels --" }
            })' />
    </div>
    <div style="display: flex; gap: 10px;">
        <button type="submit" class="btn-leaf">Apply Filters</button>
        <a asp-action="Index" class="btn-clear" style="padding: 10px 15px;">Clear</a>
    </div>
</form>

<div class="entity-catalog">
    @if (Model != null && Model.Any()) {
        foreach (var item in Model) {
            <div class="nursery-card">
                <div class="nursery-card-header">
                    <h2 class="nursery-card-title">@item.CareProfileName</h2>
                    @if (item.RequiresWinterDormancy == true) {
                        <div style="margin-top: 0.5rem;">
                            <span class="status-badge status-low">Dormancy Required</span>
                        </div>
                    }
                </div>
                <div class="nursery-card-body">
                    <p><span class="card-label">Light:</span> @item.RequiredLight</p>
                    <p><span class="card-label">Humidity:</span> @item.RequiredHumidity</p>
                    <p class="brief-desc">@item.CareDescription</p>
                </div>
                <div class="nursery-card-footer">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn-leaf">Full Care Guide &raquo;</a>
                </div>
            </div>
        }
    } else {
        <p>No care profiles found.</p>
    }
</div>
