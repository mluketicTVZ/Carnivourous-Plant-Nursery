@model Carnivorous_Plant_Nursery.Models.CareProfile

@{
    ViewData["Title"] = $"Care Guide - {Model.CareProfileName}";
}

<div class="nursery-breadcrumb">
    <a asp-controller="Home" asp-action="Index">Home</a> <span class="separator">&raquo;</span>
    <a asp-action="Index">Care Profiles</a> <span class="separator">&raquo;</span>
    <span>@Model.CareProfileName Guide</span>
</div>

<partial name="_BackButton" />

@if (TempData["DeleteError"] != null)
{
    <div class="toast-notification" data-autodismiss="true">
        <div class="toast-icon">⚠️</div>
        <div class="toast-content">
            <h4 class="toast-title">Cannot delete</h4>
            <p class="toast-message">@TempData["DeleteError"]</p>
        </div>
        <button type="button" class="toast-close" onclick="closeToast(this.closest('.toast-notification'))">&times;</button>
    </div>
}

<div class="entity-details-wrapper care-guide-card">
    <div class="details-header">
        <h1 class="details-title">Care Guide: @Model.CareProfileName</h1>
        <div class="scientific-name">
            @if (Model.RequiresWinterDormancy == true) {
                <span class="status-badge status-low">Requires Winter Dormancy</span>
            }
        </div>
    </div>
    
    <div class="details-content">
        <div class="care-stats-grid">
            <div class="stat-box light-box">
                <div class="stat-icon">☀️</div>
                <h4>Lighting</h4>
                <p>@Model.RequiredLight</p>
            </div>
            <div class="stat-box humidity-box">
                <div class="stat-icon">💧</div>
                <h4>Humidity</h4>
                <p>@Model.RequiredHumidity</p>
            </div>
            <div class="stat-box soil-box">
                <div class="stat-icon">🪴</div>
                <h4>Soil / Substrate</h4>
                <p>@Model.SoilMix</p>
            </div>
            <div class="stat-box temp-box">
                <div class="stat-icon">🌡️</div>
                <h4>Temperature</h4>
                <p>Min: @Model.MinTemperature — Max: @Model.MaxTemperature</p>
                @if (!string.IsNullOrEmpty(Model.TemperatureDescription)) {
                    <p class="temp-desc">@Model.TemperatureDescription</p>
                }
            </div>
        </div>

        <div class="detail-group instructions-box">
            <h3 class="detail-label">Care Notes</h3>
            <div class="instruction-content">
                @Html.Raw(Model.CareDescription?.Replace("\n", "<br/>") ?? "Care notes are pending for this profile.")
            </div>
        </div>

        @if (TempData["DeleteError"] != null)
        {
            <div style="background-color: #fdecea; border: 1px solid #f44336; border-left: 4px solid #c0392b; border-radius: 6px; padding: 1rem 1.2rem; margin-bottom: 1rem;">
                <strong style="color: #c0392b;">Cannot delete:</strong>
                <span style="color: #333;">@TempData["DeleteError"]</span>
            </div>
        }
        <div class="action-panel" style="margin-top: 2rem;">
            <a asp-action="Index" class="btn-leaf" style="background-color: var(--text-muted);">&laquo; Back to Care Profiles</a>
            @if (Context.Session.GetString("IsAdmin") == "true")
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-leaf">&#9998; Edit</a>
                <form id="delete-form-careprofile" asp-action="Delete" asp-route-id="@Model.Id" method="post" style="display: inline;">
                    @Html.AntiForgeryToken()
                    <button type="button" class="btn-leaf" style="background-color: #c0392b; border-color: #c0392b;" onclick="openDeleteModal('delete-form-careprofile', 'this care profile')">&#128465; Delete</button>
                </form>
            }
        </div>
    </div>
</div>
