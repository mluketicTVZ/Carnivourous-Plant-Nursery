@model IEnumerable<Carnivorous_Plant_Nursery.Models.SeedBatch>

@{
    ViewData["Title"] = "Seed Bank";
}

<div class="nursery-breadcrumb">
    <a asp-controller="Home" asp-action="Index">Home</a> <span class="separator">&raquo;</span>
    <span>Seed Bank</span>
</div>

<partial name="_BackButton" />

@if (User.IsInRole(AuthorizationRole.Admin) || User.IsInRole(AuthorizationRole.Manager))
{
    <div style="margin-bottom: 1rem;">
        <a asp-action="Create" class="btn-leaf">+ Add New Seed Batch</a>
    </div>
}

<div style="margin-bottom: 2rem;">
    <h1 style="color: var(--dark-green); border-bottom: 3px solid var(--accent-color); padding-bottom: 10px; display: inline-block;">Seed Bank & Propagation</h1>
    <p style="color: var(--text-muted); font-size: 1.1rem; margin-top: 10px;">
        Explore our curated collection of responsibly harvested carnivorous plant seeds.
    </p>
</div>

<form method="get" asp-controller="SeedBatch" asp-action="Index" class="botanical-filter-form">
    <div class="filter-group">
        <label for="autocomplete-display-searchTerm">Search by Title or SKU</label>
        <partial name="_PlantAutocomplete"
            model="@(ViewBag.SearchTerm as string)"
            view-data='@(new ViewDataDictionary(ViewData) {
                { "Endpoint", "/seeds/suggestions" },
                { "Placeholder", "Search seed batches..." }
            })' />
    </div>
    <div class="filter-group filter-group-checkbox">
        <label>
            <input type="checkbox" name="availableInWebshop" value="true" @(ViewBag.AvailableInWebshop == true ? "checked" : "") />
            Available in Webshop Only
        </label>
    </div>
    <div style="display:flex; gap:10px; align-items:flex-end;">
        <button type="submit" class="btn-filter" style="align-self: flex-end; padding: 0.6rem 1.4rem;">Apply</button>
        <a asp-action="Index" class="btn-clear" style="text-align:center; align-self: flex-end; padding: 0.6rem 1.4rem;">Clear</a>
    </div>
</form>

<div class="entity-catalog">
    @foreach (var s in Model)
    {
        <div class="nursery-card">
            <div class="nursery-card-header">
                <div class="nursery-card-title-row">
                    <div>
                        <h2 class="nursery-card-title">@(string.IsNullOrEmpty(s.ListingTitle) ? s.Taxonomy?.CommonName + " Seeds" : s.ListingTitle)</h2>
                        <div class="nursery-card-subtitle">@s.Taxonomy?.FullName</div>
                    </div>
                    <partial name="_AttachmentGallery"
                             model="s.Attachments"
                             view-data='@(new ViewDataDictionary(ViewData) {
                                 { "GallerySize", "compact" },
                                 { "GalleryLabel", $"Photos for {(string.IsNullOrEmpty(s.ListingTitle) ? s.Taxonomy?.CommonName + " Seeds" : s.ListingTitle) ?? "seed batch"}" }
                             })' />
                </div>
            </div>
            <div class="nursery-card-body">
                <p><span class="card-label">SKU:</span> @(string.IsNullOrEmpty(s.SKU) ? "N/A" : s.SKU)</p>
                <p><span class="card-label">Genus:</span> @s.Taxonomy?.Genus</p>
                <p><span class="card-label">Species:</span> @s.Taxonomy?.Species</p>
                <p><span class="card-label">Seeds:</span> @(s.SeedCount.HasValue ? s.SeedCount.Value.ToString() : "Unknown")</p>
                <p><span class="card-label">Harvested:</span> @(s.HarvestDate.HasValue ? s.HarvestDate.Value.ToString("d") : "N/A")</p>
            </div>
            <div class="nursery-card-footer">
                <a asp-action="Details" asp-route-id="@s.Id" class="btn-leaf">View Details &raquo;</a>
            </div>
        </div>
    }
</div>
