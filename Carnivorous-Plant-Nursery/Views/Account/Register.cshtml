@model Carnivorous_Plant_Nursery.Models.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<div class="nursery-breadcrumb">
    <a asp-controller="Home" asp-action="Index">Home</a> <span class="separator">&rsaquo;</span>
    <span>Register</span>
</div>

<partial name="_BackButton" />

<div class="entity-form-wrapper" style="max-width: 640px;">
    <h1 class="form-title">Create Account</h1>

    <form asp-controller="Account" asp-action="ExternalLogin" method="post" class="external-login-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="provider" value="@DisplayConstant.GoogleProvider" />
        <button type="submit" class="btn-google-login">
            <span class="google-login-mark">G</span>
            Continue with Google
        </button>
    </form>

    <div class="account-divider"><span>or create with email</span></div>

    <form asp-controller="Account" asp-action="Register" method="post">
        @Html.AntiForgeryToken()

        <fieldset class="details-section">
            <legend>Account Details</legend>

            <div asp-validation-summary="ModelOnly" class="val-error"></div>

            <div class="filter-group">
                <label asp-for="Email" class="card-label"></label>
                <input asp-for="Email" autocomplete="username" />
                <span asp-validation-for="Email" class="val-error"></span>
            </div>

            <div class="filter-group">
                <label asp-for="DisplayName" class="card-label"></label>
                <input asp-for="DisplayName" autocomplete="nickname" />
                <span asp-validation-for="DisplayName" class="val-error"></span>
            </div>

            <div class="filter-group">
                <label asp-for="PhoneNumber" class="card-label"></label>
                <input asp-for="PhoneNumber" autocomplete="tel" />
                <span asp-validation-for="PhoneNumber" class="val-error"></span>
            </div>

            <div class="filter-group">
                <label asp-for="DefaultShippingCity" class="card-label"></label>
                <input asp-for="DefaultShippingCity" autocomplete="address-level2" />
                <span asp-validation-for="DefaultShippingCity" class="val-error"></span>
            </div>
        </fieldset>

        <fieldset class="details-section">
            <legend>Security</legend>

            <div class="filter-group">
                <label asp-for="Password" class="card-label"></label>
                <input asp-for="Password" autocomplete="new-password" />
                <span asp-validation-for="Password" class="val-error"></span>
            </div>

            <div class="filter-group">
                <label asp-for="ConfirmPassword" class="card-label"></label>
                <input asp-for="ConfirmPassword" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="val-error"></span>
            </div>
        </fieldset>

        <div style="display: flex; gap: 10px; margin-top: 20px; flex-wrap: wrap;">
            <button type="submit" class="btn-leaf">Create Account</button>
            <a asp-controller="Account" asp-action="Login" class="btn-clear">I already have an account</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
