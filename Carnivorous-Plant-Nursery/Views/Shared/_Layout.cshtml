<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Carnivorous Plant Nursery</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        // Hide the page synchronously before the browser paints anything.
        // Covers two cases:
        //   1. First-ever load  — flytrap jaws will reveal it.
        //   2. Transition navigation — the enter animation will reveal it.
        if (!sessionStorage.getItem('ftSnapped') || sessionStorage.getItem('pendingTransition')) {
            document.documentElement.style.visibility = 'hidden';
        }
    </script>
</head>
<body>
    <header class="nursery-header">
        <div style="display: flex; align-items: center; gap: 1rem;">
            <a href="/" class="brand-title">
                <img src="~/images/Drosera Logo.jpg" alt="Carnivorous Plant Nursery Logo" style="height: 50px; width: 50px; border-radius: 50%; object-fit: cover; margin-right: 10px; border: 2px solid var(--primary-green);" />
                Carnivorous Plant Nursery
            </a>
            <div style="display: flex; align-items: center;">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Account" asp-action="Manage" style="font-size: 0.8rem; color: var(--text-muted); text-decoration: none;">&#128100; Account Management</a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" style="font-size: 0.8rem; color: var(--text-muted); text-decoration: none;">&#128272; Login</a>
                }
            </div>
        </div>
        <nav class="nursery-nav">
            <ul>
                <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li><a asp-controller="Plant" asp-action="Index">Plants</a></li>
                <li><a asp-controller="SeedBatch" asp-action="Index">Seeds</a></li>
                <li><a asp-controller="Taxonomy" asp-action="Index">Taxonomy</a></li>
                <li><a asp-controller="CareProfile" asp-action="Index">Care Guide</a></li>
                <li><a asp-controller="Inventory" asp-action="Index">Inventory</a></li>
            </ul>
        </nav>
    </header>
    
    <main role="main" class="main-container">
        @RenderBody()
    </main>

    <footer style="text-align: center; padding: 2rem; color: #666; margin-top: 2rem; border-top: 1px solid #eee;">
        &copy; @DateTime.Now.Year - Carnivorous Plant Nursery. Fostering a love for botanical wonders.
    </footer>

    <!-- Global Delete Modal -->
    <div id="global-delete-modal" class="modal-overlay">
        <div class="modal-box">
            <h2 class="modal-title">Confirm Deletion</h2>
            <div class="modal-body">
                Are you sure you want to delete <strong><span>this item</span></strong>? This action cannot be undone.
            </div>
            <div class="modal-actions">
                <button type="button" class="btn-leaf" style="background-color: var(--text-muted); border-color: var(--text-muted);" onclick="closeDeleteModal()">Cancel</button>
                <button type="button" class="btn-leaf" style="background-color: #c0392b; border-color: #c0392b;" onclick="confirmDelete()">&#128465; Delete</button>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
