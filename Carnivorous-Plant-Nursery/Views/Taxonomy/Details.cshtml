@model Carnivorous_Plant_Nursery.Models.Taxonomy

@{
    ViewData["Title"] = $"Taxonomy - {Model.FullName}";
}

<div class="entity-details-wrapper">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Taxonomies</a></li>
            <li class="breadcrumb-item active" aria-current="page">Details</li>
        </ol>
    </nav>

    <partial name="_BackButton" />

    <div class="details-card">
        <div class="details-header">
            <h1 class="details-title"><i>@Model.FullName</i></h1>
            <span class="badge taxonomy-badge">Taxonomy ID: @Model.Id</span>
        </div>
        
        <div class="details-content">
            <div class="detail-group">
                <h3 class="detail-label">Nomenclature</h3>
                <p class="detail-value"><strong>Genus:</strong> <i>@Model.Genus</i></p>
                <p class="detail-value"><strong>Species:</strong> <i>@Model.Species</i></p>
                @if (!string.IsNullOrEmpty(Model.Cultivar)) {
                    <p class="detail-value"><strong>Cultivar:</strong> @Model.Cultivar</p>
                }
                @if (!string.IsNullOrEmpty(Model.CommonName)) {
                    <p class="detail-value"><strong>Common Name:</strong> @Model.CommonName</p>
                }
            </div>

            @if (Model.CareProfile != null) {
                <div class="detail-group">
                    <h3 class="detail-label">Care Profile</h3>
                    <p class="detail-value"><strong>Profile:</strong> <a asp-controller="CareProfile" asp-action="Details" asp-route-id="@Model.CareProfileId">@Model.CareProfile.CareProfileName</a></p>
                    <p class="detail-value"><strong>Light:</strong> @Model.CareProfile.RequiredLight</p>
                    <p class="detail-value"><strong>Humidity:</strong> @Model.CareProfile.RequiredHumidity</p>
                </div>
            }
        </div>

        <div class="details-actions">
            <a asp-action="Index" class="nursery-btn nursery-btn-secondary">Back to Catalog</a>
        </div>
    </div>
</div>
