@model Carnivorous_Plant_Nursery.Models.Taxonomy

@{
    ViewData["Title"] = $"Taxonomy \u2014 {Model.FullName}";
}

<div class="nursery-breadcrumb">
    <a asp-controller="Home" asp-action="Index">Home</a> &rsaquo;
    <a asp-action="Index">Taxonomies</a> &rsaquo;
    <span>@Model.FullName</span>
</div>

<partial name="_BackButton" />

@if (TempData["DeleteError"] != null)
{
    <div class="toast-notification" data-autodismiss="true">
        <div class="toast-icon">⚠️</div>
        <div class="toast-content">
            <h4 class="toast-title">Cannot delete</h4>
            <p class="toast-message">@TempData["DeleteError"]</p>
        </div>
        <button type="button" class="toast-close" onclick="closeToast(this.closest('.toast-notification'))">&times;</button>
    </div>
}

<h1 style="color: var(--dark-green); border-bottom: 3px solid var(--accent-color); padding-bottom: 8px;">
    <i>@Model.FullName</i>
</h1>

<div class="entity-details-wrapper">

    <div class="details-section">
        <h3>Nomenclature</h3>
        <p><span class="card-label">Genus:</span> <i>@Model.Genus</i></p>
        <p><span class="card-label">Species:</span> <i>@Model.Species</i></p>
        @if (!string.IsNullOrEmpty(Model.Cultivar))
        {
            <p><span class="card-label">Cultivar:</span> @Model.Cultivar</p>
        }
        @if (!string.IsNullOrEmpty(Model.CommonName))
        {
            <p><span class="card-label">Common Name:</span> @Model.CommonName</p>
        }
    </div>

    @if (Model.CareProfile != null)
    {
        <div class="details-section">
            <h3>Care Profile</h3>
            <p>
                <span class="card-label">Profile:</span>
                <a asp-controller="CareProfile" asp-action="Details" asp-route-id="@Model.CareProfileId"
                   style="color: var(--primary-green); font-weight: bold;">@Model.CareProfile.CareProfileName</a>
            </p>
            <p><span class="card-label">Required Light:</span> @Model.CareProfile.RequiredLight</p>
            <p><span class="card-label">Required Humidity:</span> @Model.CareProfile.RequiredHumidity</p>
            <p><span class="card-label">Winter Dormancy:</span> @(Model.CareProfile.RequiresWinterDormancy == true ? "Required" : "Not required")</p>
        </div>
    }

    @if (Model.InventoryItems != null && Model.InventoryItems.Any())
    {
        <div class="details-section">
            <h3>Specimens</h3>
            <p><span class="card-label">In nursery:</span> @Model.InventoryItems.Count specimen(s)</p>
        </div>
    }

    @if (TempData["DeleteError"] != null)
    {
        <div style="background-color: #fdecea; border: 1px solid #f44336; border-left: 4px solid #c0392b; border-radius: 6px; padding: 1rem 1.2rem; margin-bottom: 1rem;">
            <strong style="color: #c0392b;">Cannot delete:</strong>
            <span style="color: #333;">@TempData["DeleteError"]</span>
        </div>
    }
    <div style="margin-top: 1.5rem; display: flex; gap: 10px; flex-wrap: wrap;">
        <a asp-action="Index" class="btn-leaf" style="background-color: var(--text-muted);">Back to Catalog</a>
        @if (Context.Session.GetString("IsAdmin") == "true")
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-leaf">&#9998; Edit</a>
            <form id="delete-form-taxonomy" asp-action="Delete" asp-route-id="@Model.Id" method="post" style="display: inline;">
                @Html.AntiForgeryToken()
                <button type="button" class="btn-leaf" style="background-color: #c0392b; border-color: #c0392b;" onclick="openDeleteModal('delete-form-taxonomy', 'this taxonomy')">&#128465; Delete</button>
            </form>
        }
    </div>

</div>
